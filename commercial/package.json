{
  "name": "untab-pro",
  "version": "1.0.0",
  "description": "Professional browser productivity tool with advanced tab management",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "webpack --mode=production",
    "deploy": "npm run build && npm run start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "keywords": [
    "browser-extension",
    "productivity",
    "tab-management",
    "saas",
    "chrome-extension"
  ],
  "author": "Untab Pro Team",
  "license": "Commercial",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "mongoose": "^7.5.0",
    "stripe": "^13.1.0",
    "nodemailer": "^6.9.4",
    "redis": "^4.6.7",
    "express-rate-limit": "^6.8.1",
    "compression": "^1.7.4",
    "winston": "^3.10.0",
    "joi": "^17.9.2",
    "uuid": "^9.0.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "jest": "^29.6.2",
    "eslint": "^8.46.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/601533995-star/untab.git"
  },
  "commercial": {
    "tiers": {
      "free": {
        "maxTabs": 20,
        "maxGroups": 3,
        "cloudSync": false,
        "analytics": false,
        "teamSharing": false,
        "price": 0
      },
      "pro": {
        "maxTabs": 500,
        "maxGroups": 20,
        "cloudSync": true,
        "analytics": true,
        "teamSharing": false,
        "price": 69,
        "currency": "CNY",
        "billingPeriod": "monthly"
      },
      "team": {
        "maxTabs": -1,
        "maxGroups": -1,
        "cloudSync": true,
        "analytics": true,
        "teamSharing": true,
        "price": 199,
        "currency": "CNY",
        "billingPeriod": "monthly",
        "minUsers": 5
      }
    },
    "features": {
      "advancedSearch": ["pro", "team"],
      "customThemes": ["pro", "team"],
      "prioritySupport": ["pro", "team"],
      "teamWorkspaces": ["team"],
      "slaGuarantee": ["team"]
    }
  }
}